// 主库 Prisma Schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// Enums (PostgreSQL native ENUM types)

/// 用户与机器人的关系等级
enum UserRelation {
  stranger
  group_member
  friend
  admin

  @@map("user_relation_enum")
}

/// 群成员角色
enum GroupRole {
  owner
  admin
  member

  @@map("group_role_enum")
}

/// 反馈类型
enum FeedbackType {
  bug
  suggestion
  complaint
  other

  @@map("feedback_type_enum")
}

/// 反馈状态
enum FeedbackStatus {
  pending
  done

  @@map("feedback_status_enum")
}

/// 反馈来源
enum FeedbackSource {
  group
  private

  @@map("feedback_source_enum")
}

/// 点赞触发来源
enum LikeSource {
  manual
  scheduled

  @@map("like_source")
}

// Models

/// 机器人已知用户表
model User {
  qq       String       @id @map("qq") @db.Text
  nickname String       @default("") @db.Text
  relation UserRelation @default(stranger)

  lastSynced DateTime @default(now()) @map("last_synced") @db.Timestamptz

  /**
   * Relations
   */
  memberships     GroupMembership[]
  feedbacks       Feedback[]        @relation("FeedbackUser")
  checkin_records CheckinRecord[]   @relation("CheckinUser")
  jrlp_as_user    WifeRecord[]      @relation("JrlpUser")
  jrlp_as_wife    WifeRecord[]      @relation("JrlpWife")

  @@index([relation])
  @@map("users")
}

/// 机器人群聊表
model Group {
  groupId        String  @id @map("group_id") @db.Text
  groupName      String  @default("") @map("group_name") @db.Text
  memberCount    Int     @default(0) @map("member_count")
  maxMemberCount Int     @default(0) @map("max_member_count")
  isActive       Boolean @default(true) @map("is_active")

  lastSynced DateTime @default(now()) @map("last_synced") @db.Timestamptz

  /**
   * Relations
   */
  memberships     GroupMembership[]
  feedbacks       Feedback[]        @relation("FeedbackGroup")
  checkin_records CheckinRecord[]   @relation("CheckinGroup")
  jrlp_records    WifeRecord[]      @relation("JrlpGroup")

  @@index([isActive])
  @@map("groups")
}

/// 群聊成员关系表
model GroupMembership {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Text
  groupId         String    @map("group_id") @db.Text
  card            String    @default("") @db.Text
  role            GroupRole @default(member)
  joinTime        BigInt    @default(0) @map("join_time")
  lastActiveTime  BigInt    @default(0) @map("last_active_time")
  title           String    @default("") @db.Text
  titleExpireTime BigInt    @default(0) @map("title_expire_time")
  level           String    @default("") @db.Text
  isActive        Boolean   @default(true) @map("is_active")

  /**
   * Relations
   */
  user  User  @relation(fields: [userId], references: [qq])
  group Group @relation(fields: [groupId], references: [groupId])

  @@unique([userId, groupId], map: "uq_user_group")
  @@index([userId])
  @@index([groupId])
  @@index([isActive])
  @@map("group_memberships")
}

/// LLM 供应商协议类型
enum LlmProviderType {
  openai
  anthropic
  gemini

  @@map("llm_provider_type_enum")
}

/// LLM 提供商表
model LlmProvider {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @unique @db.Text
  type          LlmProviderType
  apiBase       String          @map("api_base") @db.Text
  apiKey        String          @map("api_key") @db.Text
  maxRetries    Int             @default(2) @map("max_retries")
  timeout       Int             @default(60)
  retryInterval Int             @default(1) @map("retry_interval")

  /**
   * Relations
   */
  models LlmModel[]

  @@map("llm_providers")
}

/// LLM 模型配置表
model LlmModel {
  id          String  @id @default(uuid()) @db.Uuid
  providerId  String  @map("provider_id") @db.Uuid
  modelName   String  @map("model_name") @db.Text
  displayName String? @map("display_name") @db.Text
  inputPrice  Decimal @default(0) @map("input_price") @db.Decimal(12, 6)
  outputPrice Decimal @default(0) @map("output_price") @db.Decimal(12, 6)
  temperature Float   @default(0.7) @db.DoublePrecision
  maxTokens   Int?    @map("max_tokens")
  forceStream Boolean @default(false) @map("force_stream")
  extraParams Json    @default("{}") @map("extra_params") @db.JsonB
  isEnabled   Boolean @default(true) @map("is_enabled")

  /**
   * Relations
   */
  provider LlmProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, modelName], map: "uq_provider_model")
  @@index([providerId])
  @@map("llm_models")
}

/// 用户反馈表
model Feedback {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @map("user_id") @db.Text
  feedbackType FeedbackType?  @map("feedback_type")
  content      String         @db.Text
  status       FeedbackStatus @default(pending)
  adminReply   String?        @map("admin_reply") @db.Text
  source       FeedbackSource
  groupId      String?        @map("group_id") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  processedAt  DateTime?      @map("processed_at") @db.Timestamptz

  /**
   * Relations
   */
  user  User   @relation("FeedbackUser", fields: [userId], references: [qq], onDelete: Cascade)
  group Group? @relation("FeedbackGroup", fields: [groupId], references: [groupId], onDelete: SetNull)

  @@index([userId])
  @@index([feedbackType])
  @@index([status])
  @@index([groupId])
  @@map("feedbacks")
}

/// 站内信表 —— 全局通知日志（全局仅一个御者，无需按收件人区分）
model Mailbox {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @db.Text
  content   String    @db.Text // Markdown 格式，前端渲染
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([isRead])
  @@index([createdAt])
  @@map("mailbox")
}

/// 用户群签到记录表
model CheckinRecord {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Text
  userId      String   @map("user_id") @db.Text
  checkinDate DateTime @map("checkin_date") @db.Date
  checkinAt   DateTime @map("checkin_at") @db.Timestamptz

  /**
   * Relations
   */
  group Group @relation("CheckinGroup", fields: [groupId], references: [groupId], onDelete: Cascade)
  user  User  @relation("CheckinUser", fields: [userId], references: [qq], onDelete: Cascade)

  @@unique([groupId, userId, checkinDate], map: "uq_checkin_group_user_date")
  @@index([groupId])
  @@index([checkinDate])
  @@index([userId, groupId, checkinDate], map: "idx_checkin_user_group")
  @@map("checkin")
}

/// 今日老婆抽取/预设记录表
model WifeRecord {
  id      String    @id @default(uuid()) @db.Uuid
  groupId String    @map("group_id") @db.Text
  userId  String    @map("user_id") @db.Text
  wifeQq  String    @map("wife_qq") @db.Text
  date    DateTime  @db.Date
  drawnAt DateTime? @map("drawn_at") @db.Timestamptz

  /**
   * Relations
   */
  group Group @relation("JrlpGroup", fields: [groupId], references: [groupId], onDelete: Cascade)
  user  User  @relation("JrlpUser", fields: [userId], references: [qq], onDelete: Cascade)
  wife  User  @relation("JrlpWife", fields: [wifeQq], references: [qq], onDelete: Cascade)

  @@unique([groupId, userId, date], map: "uq_jrlp_group_user_date")
  @@index([groupId])
  @@index([userId])
  @@index([date])
  @@map("jrlp")
}

/// 定时点赞任务表
model LikeTask {
  id                String   @id @default(uuid()) @db.Uuid
  qq                String   @unique @db.Text
  registeredAt      DateTime @default(now()) @map("registered_at") @db.Timestamptz
  registeredGroupId String?  @map("registered_group_id") @db.Text

  @@map("like_tasks")
}

/// 点赞执行历史记录表
model LikeHistory {
  id          String     @id @default(uuid()) @db.Uuid
  qq          String  @db.Text
  times       Int        @db.SmallInt
  triggeredAt DateTime   @default(now()) @map("triggered_at") @db.Timestamptz
  source      LikeSource
  success     Boolean

  @@index([qq, triggeredAt], map: "ix_like_history_qq_triggered_at")
  @@index([source, triggeredAt], map: "ix_like_history_source_triggered_at")
  @@map("like_history")
}

/// 漂流瓶池表
model DriftBottlePool {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.Text

  /**
   * Relations
   */
  group_pools DriftBottleGroupPool[]
  items       DriftBottle[]

  @@map("drift_bottle_pools")
}

/// 群池映射表
model DriftBottleGroupPool {
  groupId String @id @map("group_id") @db.Text
  poolId  String @map("pool_id") @db.Uuid

  /**
   * Relations
   */
  pool DriftBottlePool @relation(fields: [poolId], references: [id], onDelete: Restrict)

  @@map("drift_bottle_group_pools")
}

/// 漂流瓶本体表
model DriftBottle {
  id            String    @id @default(uuid()) @db.Uuid
  poolId        String    @map("pool_id") @db.Uuid
  senderId      String    @map("sender_id") @db.Text
  senderGroupId String    @map("sender_group_id") @db.Text
  content       Json      @db.JsonB
  isPicked      Boolean   @default(false) @map("is_picked")
  pickedBy      String?   @map("picked_by") @db.Text
  pickedAt      DateTime? @map("picked_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  /**
   * Relations
   */
  pool DriftBottlePool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, isPicked], map: "ix_drift_bottles_pool_is_picked")
  @@index([senderId])
  @@map("drift_bottles")
}

/// 配置值类型
enum SettingType {
  boolean
  number
  string
  enumValue @map("enum")

  @@map("setting_type")
}

/// 树状 scope 动态配置覆盖表 —— scope 为空串表示系统级（根），非空时由 Path 通过 toScope() 生成
model Setting {
  id        String      @id @default(uuid()) @db.Uuid
  key       String      @db.Text
  scope     String      @db.Text
  value     String      @db.Text
  valueType SettingType @map("value_type")

  @@unique([key, scope])
  @@index([scope, key])
  @@map("settings")
}

/// 机器人账号表 —— 存储多个 NapCat 实例的连接配置。
model Account {
  qq        String  @id @db.Text
  nickname  String?
  role      String // 'master' | 'normal' | 'readonly'
  transport String // 'ws' | 'sse'
  endpoint  String // ws://host:port 或 http://host:port
  token     String? // 列级加密待后续统一设计，当前明文存储
  isEnabled Boolean @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}
