// 聊天库 Prisma Schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// Enums

/// 聊天归档任务状态
enum ArchiveStatus {
  pending
  exporting
  uploading
  uploaded
  deleting
  completed
  failed

  @@map("archive_status_enum")
}

// Models

/// 聊天记录表
/// message_type 为 IntEnum: 1=private, 2=group, 3=self_sent (SmallInt 存储)
model ChatMessage {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  createdAt DateTime @map("created_at") @db.Timestamptz

  messageId   BigInt  @map("message_id")
  messageType Int     @map("message_type") @db.SmallInt
  groupId     BigInt? @map("group_id")
  userId      BigInt  @map("user_id")

  rawMessage     String   @default("") @map("raw_message")     @db.Text
  segments       Json     @db.JsonB
  senderNickname String   @default("") @map("sender_nickname") @db.Text
  senderCard     String?  @map("sender_card")                  @db.Text
  senderRole     String?  @map("sender_role")                  @db.Text
  storedAt       DateTime @default(now()) @map("stored_at")    @db.Timestamptz

  @@index([groupId, createdAt(sort: Desc)], map: "ix_chat_group_time")
  @@index([userId, createdAt(sort: Desc)], map: "ix_chat_user_time")
  @@index([messageId, createdAt(sort: Desc)], map: "ix_chat_message_id")
  @@index([messageType, createdAt(sort: Desc)], map: "ix_chat_type_time")
  @@map("chat_history")
}

/// 聊天记录归档日志表
model ArchiveLog {
  id              String        @id @default(uuid())            @db.Uuid
  groupId         BigInt?       @map("group_id")
  seq             Int           @default(0)
  periodStart     DateTime      @map("period_start")            @db.Timestamptz
  periodEnd       DateTime      @map("period_end")              @db.Timestamptz
  totalRows       BigInt        @default(0)  @map("total_rows")
  originalBytes   BigInt        @default(0)  @map("original_bytes")
  compressedBytes BigInt        @default(0)  @map("compressed_bytes")
  s3Key           String        @default("") @map("s3_key")     @db.Text
  s3Sha256        String        @default("") @map("s3_sha256")  @db.VarChar(64)
  status          ArchiveStatus @default(pending)
  errorMessage    String?       @map("error_message")           @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  completedAt     DateTime?     @map("completed_at")            @db.Timestamptz

  @@unique([groupId, seq])
  @@index([status],               map: "ix_archive_log_status")
  @@index([groupId, periodStart], map: "ix_archive_log_group_period")
  @@map("archive_log")
}
