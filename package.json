{
  "name": "aemeath",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "author": "Aemeath Projects",
  "engines": {
    "node": ">=24.17.0"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "aemeath": "tsx scripts/cli/main.ts",
    "dev": "cross-env NODE_ENV=development LOG_FORMAT=console nodemon",
    "build": "tsup",
    "start": "cross-env NODE_ENV=production node dist/main.js",
    "worker": "cross-env NODE_ENV=production node dist/worker.js",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:frontend": "pnpm --filter frontend build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"frontend/src/**/*.{ts,vue}\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"frontend/src/**/*.{ts,vue}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:backend": "vitest run --project backend",
    "test:backend:watch": "vitest --project backend",
    "test:backend:coverage": "vitest run --project backend --coverage",
    "test:frontend": "vitest run --project frontend",
    "test:frontend:watch": "vitest --project frontend",
    "test:frontend:coverage": "vitest run --project frontend --coverage",
    "db:generate": "prisma generate --config prisma/main/prisma.config.ts && prisma generate --config prisma/iris/prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma/main/prisma.config.ts && prisma migrate deploy --config prisma/iris/prisma.config.ts",
    "db:migrate:dev:main": "prisma migrate dev --config prisma/main/prisma.config.ts",
    "db:migrate:dev:iris": "prisma migrate dev --config prisma/iris/prisma.config.ts",
    "bump": "commit-and-tag-version",
    "bump:patch": "commit-and-tag-version --release-as patch",
    "bump:minor": "commit-and-tag-version --release-as minor",
    "bump:major": "commit-and-tag-version --release-as major",
    "changelog": "commit-and-tag-version --skip.bump --skip.commit --skip.tag",
    "commit": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@aemeath-projects/exostrider": "^1.1.0",
    "@aemeath-projects/napcat": "^1.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sinclair/typebox": "^0.34.49",
    "@twemoji/svg": "^15.0.0",
    "apache-arrow": "^21.1.0",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "langchain": "^1.5.1",
    "minio": "^8.0.7",
    "parquet-wasm": "^0.7.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@inquirer/prompts": "^8.5.2",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "commit-and-tag-version": "^12.7.3",
    "commitizen": "^4.3.2",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14",
    "ora": "^9.4.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "{src,scripts,tests}/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx,vue}": [
      "prettier --write"
    ]
  },
  "imports": {
    "#prisma/main": {
      "import": {
        "types": "./prisma/main/generated/index.d.ts",
        "default": "./prisma/main/generated/index.js"
      },
      "default": "./prisma/main/generated/index.js"
    },
    "#prisma/iris": {
      "import": {
        "types": "./prisma/iris/generated/index.d.ts",
        "default": "./prisma/iris/generated/index.js"
      },
      "default": "./prisma/iris/generated/index.js"
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
